<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <AssemblyName>Spark.Mongo.R4</AssemblyName>
        <LangVersion>latest</LangVersion>
        <PackageId>Spark.Mongo.R4</PackageId>
        <Product>Spark.Mongo.R4</Product>
        <Description>MongoDB Storage Implementation for Spark</Description>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Hl7.Fhir.R4" Version="5.12.1" />
        <PackageReference Include="MongoDB.Driver" Version="3.4.2">
            <NoWarn>NU1701</NoWarn>
        </PackageReference>
        <PackageReference Include="MongoDB.Bson" Version="3.4.2">
            <NoWarn>NU1701</NoWarn>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Spark.Engine\Spark.Engine.csproj" />
    </ItemGroup>

</Project>
