{
  "name": "spark-web",
  "version": "1.0.0",
  "description": "Front-end package for Spark FHIR server",
  "config": {
    "src_js": "js",
    "src_css": "scss",
    "src_img": "images",
    "dest_js": "../wwwroot/assets/js",
    "dest_css": "../wwwroot/assets/css",
    "dest_img": "../wwwroot/assets/images",
    "dist": "../wwwroot/assets"
  },
  "scripts": {
    "//[ Utility ]//": "",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean:dist": "rm -rf $npm_package_config_dist/{js/**,css/**,images/**}",
    "clean": "npm-run-all -p clean:*",
    "create_dirs:dest_js": "npx mkdirp $npm_package_config_dest_js",
    "create_dirs:dest_css": "npx mkdirp $npm_package_config_dest_css",
    "create_dirs:dest_img": "npx mkdirp $npm_package_config_dest_img",
    "create_dirs": "npm-run-all -p create_dirs:*",
    "//[ SASS ]//": "",
    "rebuild:css": "echo 'Dart Sass does not require rebuild'",
    "compile:css": "echo 'Skipping CSS compilation - no SCSS files'",
    "compile:css:dev": "echo 'Skipping CSS compilation - no SCSS files'",
    "compile:css:watch": "echo 'Skipping CSS compilation - no SCSS files'",
    "compile:css:prod": "echo 'Skipping CSS compilation - no SCSS files'",
    "compile:css:debug": "echo 'Skipping CSS compilation - no SCSS files'",
    "//[ Javascript ]//": "",
    "compile:js": "webpack-cli",
    "compile:js:prod": "npm run compile:js -- --mode production",
    "compile:js:dev": "npm run compile:js -- --mode development --progress",
    "compile:js:watch": "npm run compile:js:dev -- --watch",
    "compile:js:debug": "npm run compile:js:watch -- --display-modules",
    "//[ Syncs ]//": "",
    "sync:img": "test -d $npm_package_config_src_img && rsync -rtvu --delete $npm_package_config_src_img/ $npm_package_config_dest_img/ || echo 'No images to sync'",
    "sync": "npm-run-all -p sync:*",
    "//[ Tasks ]//": "",
    "build": "npm-run-all clean rebuild:css create_dirs sync compile:*:prod",
    "build:dev": "npm-run-all clean rebuild:css create_dirs sync compile:*:dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firelyteam/spark.git"
  },
  "author": "",
  "bugs": {
    "url": "https://github.com/FirelyTeam/Spark/issues"
  },
  "homepage": "https://github.com/FirelyTeam/Spark",
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "bootstrap": "^5.3.3",
    "jquery": "3.7.1",
    "popper.js": "1.16.1",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "css-loader": "^7.1.2",
    "mini-css-extract-plugin": "^2.9.1",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "postcss-cli": "11.0.1",
    "postcss-custom-properties": "^14.0.6",
    "rimraf": "^6.1.2",
    "sass": "^1.97.2",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  }
}
