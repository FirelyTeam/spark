@page
@using Spark.Engine
@inject SparkSettings SparkSettings

<div class="container pt-5">
    <h1>Initialize database</h1>
    <ul>
        <li>Fhir Endpoint: @SparkSettings.Endpoint</li>
        <li>FhirRelease: @SparkSettings.FhirRelease </li>
        <li>Permissive parsing: @SparkSettings.ParserSettings</li>
        <li>Spark version: @SparkSettings.Version</li>
    </ul>
    <div>

        <input type="button" class="btn btn-danger" id="clearButton" value="Clear database" />
        <input type="button" class="btn btn-warning" id="initButton" value="Load examples" />
        <input type="button" class="btn btn-success" id="reindexButton" value="Rebuild index" />

        <div class="overflow-auto mt-5 h-50 border border-info" style="height: 50vh!important;">
            <ul id="messagesList"></ul>
        </div>

    </div>
</div>

@section scripts {
<script src="~/assets/js/signalr.js"></script>
<script>
    "use strict";

    document.addEventListener("DOMContentLoaded", function () {
        const initButton = document.getElementById("initButton");
        const clearButton = document.getElementById("clearButton");
        const reindexButton = document.getElementById("reindexButton");

        // Build connection with automatic reconnection
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/maintenanceHub", { withCredentials: true })
            .withAutomaticReconnect([0, 2000, 5000, 10000, 30000]) // Retry delays in ms
            .configureLogging(signalR.LogLevel.Information)
            .build();

        function setButtonsEnabled(enabled) {
            initButton.disabled = !enabled;
            clearButton.disabled = !enabled;
            reindexButton.disabled = !enabled;
        }

        // Start the SignalR connection
        async function startSignalRConnection() {
            try {
                await connection.start();
                console.log("SignalR Connected.");
                setButtonsEnabled(true);
            } catch (err) {
                console.error("Error connecting to SignalR:", err);
                setButtonsEnabled(false);
                setTimeout(startSignalRConnection, 5000);
            }
        }

        // Connection state handlers
        connection.onreconnecting((error) => {
            console.warn("SignalR reconnecting...", error);
            setButtonsEnabled(false);
        });

        connection.onreconnected((connectionId) => {
            console.log("SignalR reconnected. Connection ID:", connectionId);
            setButtonsEnabled(true);
            addListItem("Connection restored", "messagesList");
        });

        connection.onclose((error) => {
            console.error("SignalR connection closed:", error);
            setButtonsEnabled(false);
            addListItem("Connection lost. Attempting to reconnect...", "messagesList");
            setTimeout(startSignalRConnection, 5000);
        });

        // Start the SignalR connection
        startSignalRConnection();

        function addListItem(text, list) {
            const li = document.createElement("li");
            
            // Handle both string messages and ImportProgressMessage objects
            if (typeof text === 'string') {
                li.textContent = text;
            } else if (text && text.Message) {
                li.textContent = `[${text.Progress}%] ${text.Message}`;
            } else {
                li.textContent = JSON.stringify(text);
            }
            
            document.getElementById(list).appendChild(li);
        }

        // Listen for progress updates
        connection.on("UpdateProgress", (message) => {
            addListItem(message, "messagesList");
            const messagesList = document.querySelector('.overflow-auto');
            messagesList.scrollTop = messagesList.scrollHeight;
        });

        // Button event handlers with improved error handling
        initButton.addEventListener("click", async function (event) {
            event.preventDefault();
            if (connection.state === signalR.HubConnectionState.Connected) {
                try {
                    await connection.invoke("LoadExamplesToStore");
                } catch (err) {
                    console.error("Error invoking LoadExamplesToStore:", err);
                    addListItem(`Error: ${err.message}`, "messagesList");
                }
            } else {
                addListItem("Not connected. Please wait for connection.", "messagesList");
            }
        });

        clearButton.addEventListener("click", async function (event) {
            event.preventDefault();
            if (connection.state === signalR.HubConnectionState.Connected) {
                try {
                    await connection.invoke("ClearStore");
                } catch (err) {
                    console.error("Error invoking ClearStore:", err);
                    addListItem(`Error: ${err.message}`, "messagesList");
                }
            } else {
                addListItem("Not connected. Please wait for connection.", "messagesList");
            }
        });

        reindexButton.addEventListener("click", async function (event) {
            event.preventDefault();
            if (connection.state === signalR.HubConnectionState.Connected) {
                try {
                    await connection.invoke("RebuildIndex");
                } catch (err) {
                    console.error("Error invoking RebuildIndex:", err);
                    addListItem(`Error: ${err.message}`, "messagesList");
                }
            } else {
                addListItem("Not connected. Please wait for connection.", "messagesList");
            }
        });
    });

</script>
}
